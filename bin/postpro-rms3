#! /bin/bash

if [ -z "$POSTPRO_HOME" ]
then
    echo "POSTPRO_HOME environment variable is not defined."
    exit
fi

if [ "$#" -ne 4 ]; then
    echo "Usage: $0 initialization_date source_file history_dir destination_file"
    exit
fi

module load python/3.10.16
source $POSTPRO_HOME/venv/bin/activate

IDATE=$1
SRC=$2
HISTORY_DIR=$3
DST=$4

python $POSTPRO_HOME/postpro-rms3.py $IDATE $SRC $HISTORY_DIR $DST
