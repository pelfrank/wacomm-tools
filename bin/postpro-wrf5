#! /bin/bash

if [ -z "$POSTPRO_HOME" ]
then
    echo "POSTPRO_HOME environment variable is not defined."
    exit
fi

if [ "$#" -ne 5 ]; then
    echo "Usage: $0 initialization_date source_file source_file_1hago source_file_00 destination_file"
    exit
fi

module load python/3.10.16
source $POSTPRO_HOME/venv/bin/activate

IDATE=$1
SRC=$2
SRC_1HAGO=$3
SRC_00=$4
DST=$5

python $POSTPRO_HOME/postpro-wrf5.py $IDATE $SRC $SRC_1HAGO $SRC_00 $DST
